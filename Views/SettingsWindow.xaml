<Window x:Class="LaunchDock.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LaunchDock — Configuración"
        Width="520" Height="600"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Color de selección personalizado para TextBox y ComboBox -->
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#E94560"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#E94560"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="White"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#2A2A4A"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#2A2A4A"/>

        <!-- Sobrescribir colores de hover del sistema -->
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightBrushKey}" Color="#E94560"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightLightBrushKey}" Color="#E94560"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HotTrackBrushKey}" Color="#E94560"/>

        <!-- Estilo para ComboBoxItem que sobrescribe TODOS los colores de sistema -->
        <Style x:Key="CustomComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#2A2A4A"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Name="Border" 
                                Background="{TemplateBinding Background}" 
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#E94560"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#E94560"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="IsHighlighted" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Border" Property="Background" Value="#E94560"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo personalizado para ToggleButton del ComboBox -->
        <Style x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent" BorderBrush="Transparent" BorderThickness="0">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo para el ComboBox completo con fondo oscuro -->
        <Style x:Key="CustomComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#2A2A4A"/>
            <Setter Property="Foreground" Value="#EAEAEA"/>
            <Setter Property="BorderBrush" Value="#444466"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Name="MainBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton Name="ToggleButton"
                                                Grid.ColumnSpan="2"
                                                Style="{StaticResource ComboBoxToggleButton}"
                                                Focusable="false"
                                                IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                ClickMode="Press"/>
                                    <ContentPresenter Name="ContentSite"
                                                    Grid.Column="0"
                                                    IsHitTestVisible="False"
                                                    Content="{TemplateBinding SelectionBoxItem}"
                                                    ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                    ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                    Margin="8,6,0,6"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Left"
                                                    TextElement.Foreground="White"/>
                                    <Path Name="Arrow"
                                        Grid.Column="1"
                                        Fill="White"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Data="M 0 0 L 4 4 L 8 0 Z"/>
                                </Grid>
                            </Border>
                            <Popup Name="Popup"
                                 Placement="Bottom"
                                 IsOpen="{TemplateBinding IsDropDownOpen}"
                                 AllowsTransparency="True"
                                 Focusable="False"
                                 PopupAnimation="Slide">
                                <Grid Name="DropDown"
                                    SnapsToDevicePixels="True"
                                    MinWidth="{TemplateBinding ActualWidth}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Name="DropDownBorder"
                                        Background="#2A2A4A"
                                        BorderBrush="#444466"
                                        BorderThickness="1"/>
                                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="Background" Value="#E94560"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#EE1A1A2E" CornerRadius="14"
            BorderBrush="#33E94560" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="30" ShadowDepth="8" Opacity="0.8"/>
        </Border.Effect>

        <Grid Margin="28,24,28,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,24">
                <TextBlock Text="⚙" FontSize="22" Foreground="#E94560" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Configuración" FontSize="20" FontWeight="Bold"
                           Foreground="#EAEAEA" FontFamily="Segoe UI Semibold" VerticalAlignment="Center"/>
                <Button Content="✕" Width="28" Height="28" HorizontalAlignment="Right"
                        Style="{StaticResource IconButtonStyle}"
                        Click="Close_Click"
                        Margin="200,0,0,0"/>
            </StackPanel>

            <!-- Settings form -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,-10,0">
                <StackPanel Margin="0,0,10,0">

                    <!-- Position -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="POSICIÓN DE LA BARRA" FontSize="10" FontWeight="Bold"
                                   Foreground="#9A9AB0" Margin="0,0,0,8"/>
                        <ComboBox x:Name="PositionCombo"
                                  Style="{StaticResource CustomComboBox}"
                                  Foreground="White"
                                  FontFamily="Segoe UI" FontSize="13" Height="36"
                                  ItemContainerStyle="{StaticResource CustomComboBoxItem}">
                            <ComboBoxItem Content="Arriba (Top)" Tag="Top"/>
                            <ComboBoxItem Content="Abajo (Bottom)" Tag="Bottom"/>
                            <ComboBoxItem Content="Izquierda (Left)" Tag="Left"/>
                            <ComboBoxItem Content="Derecha (Right)" Tag="Right"/>
                            <ComboBoxItem Content="Flotante (mover libremente)" Tag="Floating"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Auto hide -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <CheckBox x:Name="AutoHideCheck"
                                  Foreground="#EAEAEA" FontFamily="Segoe UI" FontSize="13"
                                  VerticalAlignment="Center"/>
                        <TextBlock Text="  Auto-ocultar (la barra se esconde al mover el ratón fuera)"
                                   Foreground="#EAEAEA" FontFamily="Segoe UI" FontSize="13"
                                   VerticalAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Orientation -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="ORIENTACIÓN" FontSize="10" FontWeight="Bold"
                                   Foreground="#9A9AB0" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="OrientationHorizontal" Content="Horizontal" GroupName="Orientation"
                                         Foreground="#EAEAEA" FontFamily="Segoe UI" FontSize="13" Margin="0,0,16,0"/>
                            <RadioButton x:Name="OrientationVertical" Content="Vertical" GroupName="Orientation"
                                         Foreground="#EAEAEA" FontFamily="Segoe UI" FontSize="13"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Icon size -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="TAMAÑO DE ICONOS" FontSize="10" FontWeight="Bold"
                                   Foreground="#9A9AB0" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="Size16" Content="16px (pequeño)" GroupName="IconSize"
                                         Foreground="#EAEAEA" FontFamily="Segoe UI" FontSize="13" Margin="0,0,16,0"/>
                            <RadioButton x:Name="Size32" Content="32px (mediano)" GroupName="IconSize"
                                         Foreground="#EAEAEA" FontFamily="Segoe UI" FontSize="13" Margin="0,0,16,0"/>
                            <RadioButton x:Name="Size48" Content="48px (grande)" GroupName="IconSize"
                                         Foreground="#EAEAEA" FontFamily="Segoe UI" FontSize="13"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- PERSONALIZACIÓN -->
                    <Border BorderBrush="#444466" BorderThickness="0,1,0,0" Margin="0,8,0,16"/>

                    <TextBlock Text="🎨 PERSONALIZACIÓN" FontSize="12" FontWeight="Bold"
                               Foreground="#E94560" Margin="0,0,0,16"/>

                    <!-- Temas -->
                    <TextBlock Text="TEMA" FontSize="10" FontWeight="Bold"
                               Foreground="#9A9AB0" Margin="0,0,0,8"/>
                    <WrapPanel Margin="0,0,0,16" x:Name="ThemePanel">
                        <Button x:Name="ThemeOscuro"   Content="🌑 Oscuro"           Tag="Oscuro"             Margin="0,0,6,6" Padding="10,6" Cursor="Hand" Click="ThemePreset_Click" FontFamily="Segoe UI" FontSize="12" BorderThickness="1" BorderBrush="#444466" Background="#2A2A4A" Foreground="#EAEAEA"/>
                        <Button x:Name="ThemeDracula"  Content="🧛 Drácula"          Tag="Dracula"            Margin="0,0,6,6" Padding="10,6" Cursor="Hand" Click="ThemePreset_Click" FontFamily="Segoe UI" FontSize="12" BorderThickness="1" BorderBrush="#444466" Background="#2A2A4A" Foreground="#EAEAEA"/>
                        <Button x:Name="ThemeNord"     Content="🌊 Nord"             Tag="Nord"               Margin="0,0,6,6" Padding="10,6" Cursor="Hand" Click="ThemePreset_Click" FontFamily="Segoe UI" FontSize="12" BorderThickness="1" BorderBrush="#444466" Background="#2A2A4A" Foreground="#EAEAEA"/>
                        <Button x:Name="ThemeClaro"    Content="☀️ Claro"            Tag="Claro"              Margin="0,0,6,6" Padding="10,6" Cursor="Hand" Click="ThemePreset_Click" FontFamily="Segoe UI" FontSize="12" BorderThickness="1" BorderBrush="#444466" Background="#2A2A4A" Foreground="#EAEAEA"/>
                        <Button x:Name="ThemeNeuDark"  Content="🌑 Neumórfico Oscuro" Tag="NeumorficoOscuro"  Margin="0,0,6,6" Padding="10,6" Cursor="Hand" Click="ThemePreset_Click" FontFamily="Segoe UI" FontSize="12" BorderThickness="1" BorderBrush="#444466" Background="#2A2A4A" Foreground="#EAEAEA"/>
                    </WrapPanel>

                    <!-- Colores -->
                    <TextBlock Text="COLORES" FontSize="10" FontWeight="Bold"
                               Foreground="#9A9AB0" Margin="0,0,0,8"/>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Color de fondo" Foreground="#EAEAEA" FontSize="11" Margin="0,0,0,4"/>
                        <TextBox x:Name="BackgroundColorText"
                                 Background="#2A2A4A" Foreground="#EAEAEA"
                                 BorderBrush="#444466" BorderThickness="1"
                                 FontFamily="Consolas" FontSize="12" Height="32" Padding="8,6"
                                 Text="#CC1A1A2E"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Color de acento" Foreground="#EAEAEA" FontSize="11" Margin="0,0,0,4"/>
                        <TextBox x:Name="AccentColorText"
                                 Background="#2A2A4A" Foreground="#EAEAEA"
                                 BorderBrush="#444466" BorderThickness="1"
                                 FontFamily="Consolas" FontSize="12" Height="32" Padding="8,6"
                                 Text="#E94560"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="Color de texto" Foreground="#EAEAEA" FontSize="11" Margin="0,0,0,4"/>
                        <TextBox x:Name="TextColorText"
                                 Background="#2A2A4A" Foreground="#EAEAEA"
                                 BorderBrush="#444466" BorderThickness="1"
                                 FontFamily="Consolas" FontSize="12" Height="32" Padding="8,6"
                                 Text="#EAEAEA"/>
                    </StackPanel>

                    <!-- Fuente -->
                    <TextBlock Text="FUENTE" FontSize="10" FontWeight="Bold"
                               Foreground="#9A9AB0" Margin="0,0,0,8"/>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="Familia de fuente" Foreground="#EAEAEA" FontSize="11" Margin="0,0,0,4"/>
                        <ComboBox x:Name="FontFamilyCombo"
                                  Style="{StaticResource CustomComboBox}"
                                  Foreground="White"
                                  FontSize="12" Height="36"
                                  ItemContainerStyle="{StaticResource CustomComboBoxItem}">
                            <ComboBoxItem Content="Segoe UI" Tag="Segoe UI" FontFamily="Segoe UI"/>
                            <ComboBoxItem Content="Arial" Tag="Arial" FontFamily="Arial"/>
                            <ComboBoxItem Content="Calibri" Tag="Calibri" FontFamily="Calibri"/>
                            <ComboBoxItem Content="Consolas" Tag="Consolas" FontFamily="Consolas"/>
                            <ComboBoxItem Content="Courier New" Tag="Courier New" FontFamily="Courier New"/>
                            <ComboBoxItem Content="Tahoma" Tag="Tahoma" FontFamily="Tahoma"/>
                            <ComboBoxItem Content="Verdana" Tag="Verdana" FontFamily="Verdana"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="Tamaño de fuente" Foreground="#EAEAEA" FontSize="11" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal">
                            <Slider x:Name="FontSizeSlider" 
                                    Minimum="10" Maximum="20" Value="13" 
                                    Width="200" VerticalAlignment="Center"
                                    TickFrequency="1" IsSnapToTickEnabled="True"/>
                            <TextBlock Text="{Binding Value, ElementName=FontSizeSlider}" 
                                       Foreground="#EAEAEA" FontSize="12" 
                                       Margin="12,0,0,0" VerticalAlignment="Center" MinWidth="30"/>
                            <TextBlock Text="px" Foreground="#9A9AB0" FontSize="11" 
                                       Margin="2,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Radio de esquinas -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="Radio de esquinas" Foreground="#EAEAEA" FontSize="11" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal">
                            <Slider x:Name="CornerRadiusSlider"
                                    Minimum="0" Maximum="20" Value="12"
                                    Width="200" VerticalAlignment="Center"
                                    TickFrequency="1" IsSnapToTickEnabled="True"/>
                            <TextBlock Text="{Binding Value, ElementName=CornerRadiusSlider}"
                                       Foreground="#EAEAEA" FontSize="12"
                                       Margin="12,0,0,0" VerticalAlignment="Center" MinWidth="30"/>
                            <TextBlock Text="px" Foreground="#9A9AB0" FontSize="11"
                                       Margin="2,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Transparencia -->
                    <TextBlock Text="TRANSPARENCIA" FontSize="10" FontWeight="Bold"
                               Foreground="#9A9AB0" Margin="0,0,0,8"/>

                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="Opacidad" Foreground="#EAEAEA" FontSize="11" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal">
                            <Slider x:Name="OpacitySlider" 
                                    Minimum="0" Maximum="100" Value="95" 
                                    Width="200" VerticalAlignment="Center"
                                    TickFrequency="5" IsSnapToTickEnabled="True"/>
                            <TextBlock Text="{Binding Value, ElementName=OpacitySlider}" 
                                       Foreground="#EAEAEA" FontSize="12" 
                                       Margin="12,0,0,0" VerticalAlignment="Center" MinWidth="30"/>
                            <TextBlock Text="%" Foreground="#9A9AB0" FontSize="11" 
                                       Margin="2,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Margin="0,16,0,0">
                <!-- Botón limpiar caché de iconos -->
                <Border Background="#1A1A2E" BorderBrush="#333355" BorderThickness="1"
                        CornerRadius="6" Padding="12,10" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="🖼 Caché de iconos" Foreground="#EAEAEA"
                                       FontFamily="Segoe UI Semibold" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock x:Name="CacheInfoText"
                                       Text="Regenera iconos si alguno se ve con fondo negro o incorrecto"
                                       Foreground="#9A9AB0" FontFamily="Segoe UI" FontSize="11"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <Button Grid.Column="1" x:Name="ClearCacheBtn"
                                Content="🗑 Limpiar" Click="ClearCache_Click"
                                Background="#2A2A4A" Foreground="#9A9AB0"
                                BorderThickness="1" BorderBrush="#444466"
                                Padding="12,6" FontFamily="Segoe UI" FontSize="12"
                                Cursor="Hand" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
                <!-- Cancelar / Guardar -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancelar" Click="Cancel_Click"
                            Background="#2A2A4A" Foreground="#9A9AB0"
                            BorderThickness="1" BorderBrush="#444466"
                            Padding="16,8" FontFamily="Segoe UI" FontSize="13" Cursor="Hand"
                            Width="100" Margin="0,0,12,0"/>
                    <Button Content="Guardar" Click="Save_Click"
                            Background="#E94560" Foreground="White"
                            BorderThickness="0"
                            Padding="16,8" FontFamily="Segoe UI Semibold" FontSize="13"
                            FontWeight="SemiBold" Cursor="Hand" Width="100"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
